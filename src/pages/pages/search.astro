---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, getPostUrl } from '../../lib/posts';
import { withBase } from '../../lib/site';

const posts = await getPosts();
---

<BaseLayout title="搜索">
  <div class="page page-search">
    <input
      id="search-input"
      type="text"
      placeholder="请在这里输入关键词^_^"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
    />
    <h1>
      <span>搜索结果</span>
      <i class="svg-icon icon-loading"></i>
    </h1>
    <ul class="list-search">
      {posts.map((post) => (
        <li hidden>
          <a href={withBase(getPostUrl(post))}>
            <p class="title">{post.data.title}</p>
            <p class="content"></p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
