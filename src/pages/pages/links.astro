---
import PostLayout from '../../layouts/PostLayout.astro';
import { site } from '../../lib/site';
---

<PostLayout title="友情链接">
  <p>欢迎各位朋友与我建立友链，本站的友链信息如下</p>
  <pre><code>{`名称：${site.title}
描述：${site.description}
地址：${site.domainUrl}${site.baseUrl}
头像：${site.domainUrl}${site.baseUrl}/static/img/site-avatar.png`}</code></pre>
  <ul>
    {site.links.map((link) => (
      <li><p><a href={link.url} title={link.desc} target="_blank">{link.title}</a></p></li>
    ))}
  </ul>
</PostLayout>
